name: Versprochen Pipeline

on:
  workflow_dispatch:

  schedule:
    - cron: "0 20 * * 5"

jobs:
  run-pipeline:
    runs-on: ubuntu-latest
    steps:
      - name: Trigger Pipeline
        run: |
          curl -X POST \
            -H "Authorization: Bearer ${{ secrets.PIPELINE_SECRET }}" \
            -H "Content-Type: application/json" \
            "${{ secrets.APP_URL }}/api/pipeline"
        env:
          PIPELINE_SECRET: ${{ secrets.PIPELINE_SECRET }}
          APP_URL: ${{ secrets.APP_URL }}
